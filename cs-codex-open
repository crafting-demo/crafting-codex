#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
setup_script="${script_dir}/skills/crafting-sandbox/scripts/setup-crafting-codex-remote.sh"

usage() {
  cat <<'EOF'
Usage:
  cs codex-open SANDBOX[/WORKLOAD] [SSH_ALIAS] [options]
  cs codex-open open SANDBOX[/WORKLOAD] [SSH_ALIAS] [options]

Open a manually-created Crafting sandbox in Codex Desktop.

Arguments:
  SANDBOX[/WORKLOAD]  Sandbox name, optionally followed by workload/workspace.
                      If WORKLOAD is omitted, the setup script uses the first
                      SSH-capable workload reported by Crafting.
  SSH_ALIAS           Optional SSH alias to write into ~/.ssh/config.

Options:
  -W, --workload NAME       Workload/workspace name. Overrides /WORKLOAD.
  -O, --org NAME            Crafting org to pass to cs.
  --ssh-host HOST           Explicit workload SSH host override.
  --remote-user USER        Remote SSH user. Default: owner.
  --project-dir DIR         Remote project folder. Default: remote login dir.
  --secret-path PATH        Preferred remote OpenAI API key secret path.
  --install-codex           Install Node.js, npm, and @openai/codex if needed. Default.
  --no-install-codex        Do not install remote Codex if it is missing.
  --skip-login              Do not try to log remote Codex in.
  --no-open                 Prepare the remote but do not launch Codex Desktop.
  --app-path PATH           Local path to open with Codex Desktop. Default: .
  -h, --help                Show this help.

Examples:
  cs codex-open SANDBOX/WORKLOAD
  cs codex-open SANDBOX/WORKLOAD SSH_ALIAS
  cs codex-open SANDBOX --workload WORKLOAD --project-dir /path/to/repo
  cs codex-open FOLDER/SANDBOX --workload WORKLOAD --alias SSH_ALIAS

Notes:
  The extension creates/updates the SSH alias and verifies the remote Codex CLI.
  Codex Desktop may still require you to enable the SSH connection under
  Settings -> Connections -> SSH and choose the remote project folder.
EOF
}

die() {
  printf 'cs codex-open: %s\n' "$*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

ensure_org_selected() {
  if [[ -n "$ssh_host" || -n "${CODEX_CRAFTING_SSH_HOST:-}" ]]; then
    return 0
  fi
  if [[ -n "$org" || -n "${CODEX_CRAFTING_ORG:-}" || -n "${CRAFTING_SANDBOX_ORG:-}" ]]; then
    return 0
  fi

  # Run a foreground command before any piped lookups so `cs` can prompt for
  # the org once and persist the selected context.
  cs sb list >/dev/null
}

sandbox_exists() {
  local target="$1"
  local target_folder=""
  local target_bare="$target"
  local args=()

  if [[ -n "$org" ]]; then
    args+=("-O" "$org")
  fi
  if [[ "$target" == */* ]]; then
    target_folder="${target%/*}"
    target_bare="${target##*/}"
    args+=("--folder" "$target_folder")
  fi

  NO_COLOR=1 cs "${args[@]}" sb show "$target_bare" >/dev/null 2>&1
}

open_codex() {
  local app_path="$1"

  if command -v codex >/dev/null 2>&1; then
    codex app "$app_path"
    return 0
  fi

  if [[ "$(uname -s)" == "Darwin" ]]; then
    open -a Codex "$app_path"
    return 0
  fi

  die "could not find 'codex' on PATH; install Codex CLI or open Codex Desktop manually"
}

command_name="open"
if [[ "${1:-}" == "open" ]]; then
  shift
elif [[ "${1:-}" == "help" ]]; then
  usage
  exit 0
fi

sandbox_target=""
alias_name=""
workload=""
org=""
remote_user=""
project_dir=""
secret_path=""
ssh_host=""
skip_login=0
install_codex=1
should_open=1
app_path="."

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -W|--workload)
      [[ $# -ge 2 ]] || die "--workload requires a value"
      workload="$2"
      shift 2
      ;;
    -O|--org)
      [[ $# -ge 2 ]] || die "--org requires a value"
      org="$2"
      shift 2
      ;;
    --alias)
      [[ $# -ge 2 ]] || die "--alias requires a value"
      alias_name="$2"
      shift 2
      ;;
    --remote-user)
      [[ $# -ge 2 ]] || die "--remote-user requires a value"
      remote_user="$2"
      shift 2
      ;;
    --ssh-host)
      [[ $# -ge 2 ]] || die "--ssh-host requires a value"
      ssh_host="$2"
      shift 2
      ;;
    --project-dir)
      [[ $# -ge 2 ]] || die "--project-dir requires a value"
      project_dir="$2"
      shift 2
      ;;
    --secret-path)
      [[ $# -ge 2 ]] || die "--secret-path requires a value"
      secret_path="$2"
      shift 2
      ;;
    --install-codex)
      install_codex=1
      shift
      ;;
    --no-install-codex)
      install_codex=0
      shift
      ;;
    --skip-login)
      skip_login=1
      shift
      ;;
    --no-open)
      should_open=0
      shift
      ;;
    --app-path)
      [[ $# -ge 2 ]] || die "--app-path requires a value"
      app_path="$2"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      if [[ -z "$sandbox_target" ]]; then
        sandbox_target="$1"
      elif [[ -z "$alias_name" ]]; then
        alias_name="$1"
      else
        die "unexpected argument: $1"
      fi
      shift
      ;;
  esac
done

[[ "$command_name" == "open" ]] || die "unsupported command: ${command_name}"
[[ -n "$sandbox_target" ]] || {
  usage >&2
  exit 2
}
[[ -x "$setup_script" ]] || die "setup script is not executable: ${setup_script}"

require_cmd cs
require_cmd ssh
ensure_org_selected

sandbox_name="$sandbox_target"
if [[ "$sandbox_target" == */* && -z "$workload" ]]; then
  if sandbox_exists "$sandbox_target"; then
    sandbox_name="$sandbox_target"
  elif sandbox_exists "${sandbox_target%/*}"; then
    sandbox_name="${sandbox_target%/*}"
    workload="${sandbox_target##*/}"
  else
    sandbox_name="${sandbox_target%/*}"
    workload="${sandbox_target##*/}"
  fi
fi

env_args=()
if [[ -n "$workload" ]]; then
  env_args+=("CODEX_CRAFTING_WORKLOAD=${workload}")
fi
if [[ -n "$org" ]]; then
  env_args+=("CODEX_CRAFTING_ORG=${org}")
fi
if [[ -n "$remote_user" ]]; then
  env_args+=("CODEX_CRAFTING_REMOTE_USER=${remote_user}")
fi
if [[ -n "$ssh_host" ]]; then
  env_args+=("CODEX_CRAFTING_SSH_HOST=${ssh_host}")
fi
if [[ -n "$project_dir" ]]; then
  env_args+=("CODEX_CRAFTING_PROJECT_DIR=${project_dir}")
fi
if [[ -n "$secret_path" ]]; then
  env_args+=("CODEX_CRAFTING_SECRET_PATH=${secret_path}")
fi
if [[ "$skip_login" == "1" ]]; then
  env_args+=("CODEX_CRAFTING_SKIP_LOGIN=1")
fi
if [[ "$install_codex" == "1" ]]; then
  env_args+=("CODEX_CRAFTING_INSTALL_CODEX=1")
else
  env_args+=("CODEX_CRAFTING_INSTALL_CODEX=0")
fi

setup_args=("$sandbox_name")
if [[ -n "$alias_name" ]]; then
  setup_args+=("$alias_name")
fi

env "${env_args[@]}" "$setup_script" "${setup_args[@]}"

if [[ "$should_open" == "1" ]]; then
  open_codex "$app_path"
fi
